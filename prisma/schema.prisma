// Prisma schema for AI Triage Copilot.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEMBER
  ADMIN
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Category {
  BUG
  FEATURE
  QUESTION
  PERFORMANCE
  SECURITY
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TriageStatus {
  PENDING
  DONE
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())

  reportedIssues  Issue[]    @relation("ReportedIssues")
  assignedIssues  Issue[]    @relation("AssignedIssues")
  comments        Comment[]
  auditLogEntries AuditLog[]
}

model Issue {
  id          String @id @default(cuid())
  title       String
  description String

  reporterId String
  reporter   User    @relation("ReportedIssues", fields: [reporterId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?   @relation("AssignedIssues", fields: [assigneeId], references: [id], onDelete: SetNull)

  status Status @default(OPEN)

  aiCategory         Category?
  aiPriority         Priority?
  aiRootCause        String?
  aiSuggestedStep    String?
  aiConfidence       Float?
  triageStatus       TriageStatus @default(PENDING)
  priorityOverridden Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  auditLogs AuditLog[]

  @@index([reporterId])
  @@index([assigneeId])
  @@index([status])
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([issueId])
}

model AuditLog {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  action    String
  createdAt DateTime @default(now())

  @@index([issueId])
}
