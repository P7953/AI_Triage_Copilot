# --- Database (Neon Postgres) ---
# Pooled connection string, used by the app at runtime.
DATABASE_URL="postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct (unpooled) connection string, used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# --- AI provider (pick one; set AI_PROVIDER accordingly) ---
AI_PROVIDER="google"
GROQ_API_KEY="replace-with-your-groq-api-key"
GOOGLE_GENERATIVE_AI_API_KEY="replace-with-your-gemini-api-key"
